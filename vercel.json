{
  "functions": {
    "api/gerar.js": { "maxDuration": 30 },
    "api/surpreenda.js": { "maxDuration": 30 },
    "api/salvar-perfil.js": { "maxDuration": 10 }
  },
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "https://www.psfeditoraeconsultoria.com.br" },
        { "key": "Access-Control-Allow-Methods", "value": "POST, OPTIONS" },
        { "key": "Access-Control-Allow-Headers", "value": "Content-Type" }
      ]
    }
  ]
}
